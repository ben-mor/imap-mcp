# mailboxes.toml — list of IMAP accounts
#
# Copy to mailboxes.toml (git-ignored) and add one [mailbox.<name>] section
# per account.  The name is the identifier used in every MCP tool call.
# Credentials live in .config/<name>/connection.json — never in this file.

[mailbox.personal]
config_dir = ".config/personal"

[mailbox.work]
config_dir = ".config/work"
