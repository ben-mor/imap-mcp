# ── Required ───────────────────────────────────────────────────────────────────
IMAP_HOST=mail.example.com
IMAP_USER=you@example.com
IMAP_PASSWORD=your-password-here

# ── Optional ───────────────────────────────────────────────────────────────────

# Port to connect on.
# 993 = implicit TLS (IMAPS)  ← default
# 143 = STARTTLS (set IMAP_USE_SSL=false)
IMAP_PORT=993

# Set to false to use STARTTLS on port 143 instead of implicit TLS on 993.
IMAP_USE_SSL=true

# Default folder for list_emails / get_email / mark_as_read / move_mail
# when no folder argument is passed.
IMAP_FOLDER=INBOX

# Comma-separated patterns (case-insensitive substring match) that are
# blocked as move_mail destinations.  Prevents accidentally triggering
# mail delivery by moving a message into an outgoing queue folder.
IMAP_PROHIBITED_FOLDERS=Sent,Outbox,Queue,Drafts

# Socket timeout in seconds for all IMAP operations.  Default: 30 s.
IMAP_TIMEOUT=30

# Maximum raw message size get_email will fetch (bytes).  Default: 20 MB.
# Raise this only if you regularly need to inspect very large emails.
IMAP_MAX_BODY_BYTES=20971520
